# .dockerignore — controls what gets sent to the Docker build context.
#
# IMPORTANT: this is completely separate from .gitignore. Git ignoring a
# folder has ZERO effect on `docker build` — Docker reads only this file.
# Without it, every build re-transfers the entire contents of
# cloned_repos/ and faiss_indexes/ as build context before building even
# starts.

# Runtime data
cloned_repos/
faiss_indexes/
mysql_data/

# Python cache / bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environments
venv/
.venv/
env/

# Git metadata
.git/
.gitignore

# Secrets — never bake credentials into an image layer
.env
.env.*
!.env.example

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.db

# Docs
README.md
*.md

# Logs
logs/
*.log

# Local test files generated during manual API testing
request.json
clone_request.json
hello_world_request.json
fastapi_request.json
readme_request.json
readme_output*.md
api_output.md
arch_output.md
file_docs_output.md
followup_request.json