# Dockerfile.streamlit — production image for the Streamlit frontend.
#
# Deliberately separate from Dockerfile.prod (the backend image): the
# backend needs torch/sentence-transformers/faiss (heavy), the frontend
# only needs streamlit + httpx (light). Building them as one shared image
# would force the frontend to carry ~1GB+ of ML dependencies it never uses.

FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r appuser && useradd -r -g appuser -m appuser

WORKDIR /app

# Install ONLY what the frontend actually needs — not the full
# requirements.txt, which would pull in torch/faiss/langchain for no reason.
RUN pip install --no-cache-dir streamlit==1.33.0 httpx==0.27.0

COPY --chown=appuser:appuser frontend/ ./frontend/

USER appuser

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "frontend/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--browser.gatherUsageStats=false"]
