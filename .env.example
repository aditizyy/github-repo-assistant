# .env.example — copy this to .env and fill in real values.
# .env itself is gitignored and must NEVER be committed.

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=repo_assistant
DB_USER=root
DB_PASSWORD=change_me_to_a_real_password

# Gemini API — get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# App settings
REPOS_DIR=./cloned_repos
FAISS_DIR=./faiss_indexes
APP_ENV=development
